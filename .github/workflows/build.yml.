name: Deploy Flet Web to GitHub Pages

on:
  push:
    branches:
      - основной # Твоя ветка на русском языке

permissions:
  contents: read
  pages: write
  id-token: write

concurrency:
  group: "pages"
  cancel-in-progress: false

jobs:
  build-and-deploy:
    environment:
      name: github-pages
      url: ${{ steps.deployment.outputs.page_url }}
    runs-on: ubuntu-latest
    steps:
      - name: Checkout code
        uses: actions/checkout@v4

      - name: Set up Python
        uses: actions/setup-python@v5
        with:
          python-version: '3.11'

      - name: Install dependencies
        run: |
          python -m pip install --upgrade pip
          if [ -f requirements.txt ]; then 
            pip install -r requirements.txt
          elif [ -f PythonProject/requirements.txt ]; then
            pip install -r PythonProject/requirements.txt
          fi
          pip install flet rich

      - name: Build Web App
        run: |
          # Устанавливаем принудительный режим без вопросов (non-interactive)
          export FLET_NON_INTERACTIVE=true
          
          # Запускаем сборку, явно указав имя модуля-папки
          flet build web --module-name PythonProject.main --base-url /${{ github.event.repository.name }}/

      - name: Upload artifact
        uses: actions/upload-pages-artifact@v3
        with:
          path: build/web

      - name: Deploy to GitHub Pages
        id: deployment
        uses: actions/deploy-pages@v4
